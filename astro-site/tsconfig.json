{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@lib/*": ["./src/lib/*"],
      "@content/*": ["./src/content/*"],
      "@i18n/*": ["./src/i18n/*"]
    },
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*", "netlify/**/*", "tests/**/*", "*.ts", "*.mjs"],
  "exclude": ["dist", "node_modules"]
}
